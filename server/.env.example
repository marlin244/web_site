PORT=3001
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# Yandex Cloud YDB
YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
YDB_DATABASE=/ru-central1/your-folder-id/your-database-id
YDB_SA_KEY_FILE=./sa-key.json

# Admin credentials (used for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_immediately

# VK Bot webhook secret
VK_WEBHOOK_SECRET=your_vk_secret

# File upload (local for dev, replace with S3/Object Storage for prod)
UPLOAD_DIR=./uploads
